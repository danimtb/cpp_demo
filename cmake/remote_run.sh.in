#!/usr/bin/env bash

unset LD_LIBRARY_PATH

remote_workdir=@REMOTE_WORKING_DIR@/build
executable_basename=$(basename $1)
executable_dirname=$(dirname $1)
executable_relpath=$(realpath --relative-to=@CMAKE_BINARY_DIR@ $executable_dirname)

remote_executable=$remote_workdir/$executable_relpath/$executable_basename

ssh @REMOTE_HOST@ 'mkdir -p ${remote_workdir}/${executable_relpath}'

cat $1 | ssh @REMOTE_HOST@ "cat >  ${remote_executable} ; chmod +x ${remote_executable}; echo LD_LIBRARY_PATH=/usr/lib/aarch64-linux-gnu/:/usr/lib/aarch64-linux-gnu/nvidia/:@REMOTE_LD_LIBRARY_PATH@ > ${remote_workdir}/ld_library_path.txt ; LD_LIBRARY_PATH=/usr/lib/aarch64-linux-gnu/:/usr/lib/aarch64-linux-gnu/nvidia/:@REMOTE_LD_LIBRARY_PATH@ ${remote_executable} ${@:2}"
